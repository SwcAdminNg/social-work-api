APP_NAME=Social Workers API
APP_ENV=local
DEBUG=true
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=social_workers

# JWT / tokens
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EXTENDED_ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Frontend (base URL, used to build links sent in emails, e.g. password reset)
FRONTEND_URL=http://localhost:3000

# SMTP (Gmail) - use a Google "App Password", not your normal account password.
# Generate one at https://myaccount.google.com/apppasswords (requires 2FA enabled).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=youraddress@gmail.com
SMTP_FROM_NAME=Social Workers
SMTP_USE_TLS=true

# Cloudflare R2 (course documents - S3-compatible presigned upload/download URLs)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=course-documents
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
PRESIGNED_URL_EXPIRE_SECONDS=600

# Bunny.net Stream (course videos - TUS resumable uploads direct from the frontend)
BUNNY_STREAM_LIBRARY_ID=your-bunny-library-id
BUNNY_STREAM_API_KEY=your-bunny-stream-api-key
BUNNY_STREAM_CDN_HOSTNAME=your-pull-zone.b-cdn.net
BUNNY_TUS_UPLOAD_EXPIRE_SECONDS=3600
# Shared secret appended as ?secret=... to the Bunny webhook URL you configure in the Bunny panel
BUNNY_WEBHOOK_SECRET=change-this-to-a-long-random-string
BUNNY_STREAM_TOKEN_AUTH_KEY=your_token_key_here

# Paystack (payment processing)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
# Paystack Webhook Url Sample -> https://qstash.upstash.io/v2/publish/https://81f3-102-88-55-219.ngrok-free.app/payments/webhook?qstash_token=******

# --- UPSTASH QSTASH ---
# Webhook and background task delivery
QSTASH_URL="https://qstash-eu-central-1.upstash.io"
QSTASH_TOKEN="your_qstash_token"
QSTASH_CURRENT_SIGNING_KEY="your_current_signing_key"
QSTASH_NEXT_SIGNING_KEY="your_next_signing_key"
